#!/usr/bin/env python3
"""
sagemake — Build system for JanusDBG

Unified debugging and profiling for heterogeneous ARM + RISC-V SoCs.

Usage:
    ./sagemake [command] [flags]

Commands:
    build           Generate JIT launcher for native target
    build-all       Generate JIT launchers for all targets
    build-vscode    Compile the VS Code extension (npm install + tsc)
    install-vscode  Build and install VS Code extension via code CLI
    check           Lint all Sage source files
    test            Run the test suite
    run             Run the backend in interpreter mode
    install         Install built artifact
    clean           Remove build artifacts
    deploy          Build deploy bundle + JIT launcher
    all             Run check, test, then build
"""

import os
import platform
import shutil
import subprocess
import sys
from pathlib import Path

RESET = "\033[0m"
BOLD = "\033[1m"
RED = "\033[31m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
CYAN = "\033[36m"

ROOT = Path(__file__).resolve().parent
SAGE = ROOT / "deps" / "SageLang" / "sage"
SRC_DIR = ROOT / "src"
LIB_DIR = ROOT / "lib"
TEST_DIR = ROOT / "tests"
BUILD_DIR = ROOT / "build"
VSCODE_DIR = ROOT / "vscode-extension"
BINARY_NAME = "janusdbgd"

ALL_TARGETS = ["x86", "x86_64", "rv32", "rv64", "arm32", "aarch64"]


def banner(title: str) -> None:
    width = 60
    line = f"{CYAN}{'═' * width}{RESET}"
    print(f"\n{line}")
    print(f"{CYAN}  {BOLD}{title}{RESET}")
    print(f"{line}\n")


def section(title: str) -> None:
    print(f"  {CYAN}→{RESET} {title}")


def step(msg: str) -> None:
    print(f"    {msg} ... ", end="", flush=True)


def ok() -> None:
    print(f"{GREEN}✓ done{RESET}")


def step_ok(detail: str) -> None:
    print(f"{GREEN}✓ {detail}{RESET}")


def step_fail(detail: str) -> None:
    print(f"{RED}✗ {detail}{RESET}")
    sys.exit(1)


def step_warn(detail: str) -> None:
    print(f"{YELLOW}! {detail}{RESET}")


def run_cmd(cmd: list[str], **kwargs) -> subprocess.CompletedProcess:
    try:
        return subprocess.run(cmd, check=True, **kwargs)
    except subprocess.CalledProcessError as e:
        step_fail(f"command failed: {' '.join(cmd)} (exit {e.returncode})")
    except FileNotFoundError:
        step_fail(f"command not found: {cmd[0]}")
    return None  # unreachable


def sage_source_files() -> list[Path]:
    files = []
    for d in [SRC_DIR, LIB_DIR]:
        for p in d.rglob("*.sage"):
            files.append(p)
    return sorted(files)


def cmd_check(args: list[str]) -> None:
    banner("check — JanusDBG")
    sage_bin = str(SAGE) if SAGE.exists() else shutil.which("sage")
    if not sage_bin:
        step_warn("sage interpreter not found — skipping lint")
        return
    section("Linting source files")
    files = sage_source_files()
    errors = 0
    for f in files:
        rel = f.relative_to(ROOT)
        step(f"linting {rel}")
        result = subprocess.run(
            [sage_bin, "lint", str(f)],
            capture_output=True, text=True,
        )
        if result.returncode != 0:
            errors += 1
            print(f"{RED}✗{RESET}")
            print(result.stdout)
        else:
            ok()
    if errors:
        step_fail(f"{errors} file(s) failed linting")


def cmd_test(args: list[str]) -> None:
    banner("test — JanusDBG")
    sage_path = f"{LIB_DIR}:{SRC_DIR}"
    env = os.environ.copy()
    env["SAGE_PATH"] = sage_path

    section("Test suite")
    step("running tests")
    if not SAGE.exists():
        step_fail("sage interpreter not built — run make -C deps/SageLang first")
    run_cmd([str(SAGE), str(TEST_DIR / "run_all.sage")], env=env)
    step_ok("all tests passed")


def cmd_deploy(args: list[str]) -> None:
    """Build the deploy bundle + JIT launcher for native target."""
    banner("deploy — JanusDBG")
    deploy_script = ROOT / "tools" / "deploy.py"
    if not deploy_script.exists():
        step_fail("tools/deploy.py not found")
    section("Generating JIT launcher")
    target = args[0] if args else "native"
    step("bundling and generating launcher")
    result = subprocess.run(
        [sys.executable, str(deploy_script), target],
        capture_output=True, text=True, cwd=ROOT,
    )
    if result.returncode != 0:
        print(result.stderr)
        step_fail("deploy failed")
    for line in result.stdout.splitlines():
        if "Output:" in line or "Bundled:" in line:
            step_ok(line.strip())
    step_ok("JIT launcher ready")


def cmd_build(args: list[str]) -> None:
    """Build JIT launcher for native architecture or a specific target."""
    banner("build — JanusDBG")
    target = args[0] if args else platform.machine()
    # Normalise arch names
    arch_map = {"x86_64": "x86_64", "aarch64": "aarch64", "armv7l": "arm32",
                "i686": "x86", "i386": "x86", "riscv64": "rv64", "riscv32": "rv32"}
    target = arch_map.get(target, target)

    try:
        cmd_test([])
    except SystemExit:
        step_fail("tests must pass before build")

    cmd_deploy([target])

    try:
        cmd_test([])
    except SystemExit:
        step_fail("tests must pass after build")

    step_ok(f"{BINARY_NAME} ready for {target}")


def cmd_build_all(args: list[str]) -> None:
    """Build JIT launchers for all targets."""
    banner("build-all — JanusDBG")

    try:
        cmd_test([])
    except SystemExit:
        step_fail("tests must pass before build")

    successes = []
    failures = []

    for target in ALL_TARGETS:
        section(f"Building for {target}")
        try:
            cmd_deploy([target])
            successes.append(target)
        except SystemExit:
            step_warn(f"build failed for {target}")
            failures.append(target)

    print()
    print(f"  {GREEN}{len(successes)} targets succeeded{RESET}: {', '.join(successes)}")
    if failures:
        print(f"  {RED}{len(failures)} targets failed{RESET}: {', '.join(failures)}")

    try:
        cmd_test([])
    except SystemExit:
        step_fail("tests must pass after build")

    if failures:
        step_fail("some targets failed")


def cmd_run(args: list[str]) -> None:
    banner("run — JanusDBG")
    sage_path = f"{LIB_DIR}:{SRC_DIR}"
    env = os.environ.copy()
    env["SAGE_PATH"] = sage_path
    section("Starting backend (interpreter mode)")
    if not SAGE.exists():
        step_fail("sage interpreter not built — run make -C deps/SageLang first")
    cmd = [str(SAGE), str(SRC_DIR / "main.sage")] + args
    print(f"  Command: {' '.join(cmd)}")
    run_cmd(cmd, env=env)


def cmd_install(args: list[str]) -> None:
    """Install JIT launcher to /usr/local/bin."""
    banner("install — JanusDBG")
    install_dir = Path("/usr/local/bin")
    target = args[0] if args else "native"
    launcher = BUILD_DIR / f"{BINARY_NAME}_{target}"
    if not launcher.exists():
        step_fail(f"{launcher.name} not built — run build first")
    dest = install_dir / BINARY_NAME
    step(f"installing to {dest}")
    try:
        install_dir.mkdir(parents=True, exist_ok=True)
        shutil.copy2(launcher, dest)
        dest.chmod(0o755)
    except PermissionError:
        step_fail(f"permission denied (try sudo)")
    step_ok(f"installed {BINARY_NAME}")


def cmd_clean(args: list[str]) -> None:
    banner("clean — JanusDBG")
    section("Removing build artifacts")
    step(f"removing {BUILD_DIR}")
    if BUILD_DIR.exists():
        shutil.rmtree(BUILD_DIR)
    ok()


def cmd_build_vscode(args: list[str]) -> None:
    """Compile the VS Code extension (npm install + tsc)."""
    banner("build-vscode — JanusDBG")
    if not VSCODE_DIR.exists():
        step_fail("vscode-extension/ directory not found")
    section("Installing npm dependencies")
    step("npm install")
    run_cmd(["npm", "install", "--no-audit", "--no-fund"], cwd=VSCODE_DIR)
    ok()
    section("Compiling TypeScript")
    step("tsc")
    run_cmd(["npx", "tsc", "-p", "./"], cwd=VSCODE_DIR)
    ok()
    step_ok("VS Code extension compiled")


def cmd_install_vscode(args: list[str]) -> None:
    """Build and install the VS Code extension via code CLI."""
    banner("install-vscode — JanusDBG")

    if not VSCODE_DIR.exists():
        step_fail("vscode-extension/ directory not found")

    # Build first
    try:
        cmd_build_vscode(args)
    except SystemExit:
        step_fail("VS Code extension build failed")

    section("Packaging extension")
    vsix_path = VSCODE_DIR / "janusdbg.vsix"

    # Check for vsce
    vsce = shutil.which("vsce") or shutil.which("npx")
    if not vsce:
        step_warn("vsce not found — trying npx vsce")
        vsce = "npx"

    step("vsce package")
    if vsce.endswith("npx"):
        run_cmd(["npx", "-y", "@vscode/vsce", "package", "-o", str(vsix_path)], cwd=VSCODE_DIR)
    else:
        run_cmd(["vsce", "package", "-o", str(vsix_path)], cwd=VSCODE_DIR)
    ok()

    section("Installing extension")
    code_cli = shutil.which("code")
    if not code_cli:
        step_warn("code CLI not found — extension packaged but not installed")
        step_ok(f"VSIX at {vsix_path}")
        return

    step("code --install-extension")
    run_cmd([code_cli, "--install-extension", str(vsix_path)])
    ok()
    step_ok("VS Code extension installed")


def cmd_all(args: list[str]) -> None:
    cmd_check(args)
    cmd_test(args)
    cmd_build_all(args)


def check_dependencies() -> None:
    section("Dependencies")
    required = []
    missing = []
    for dep in required:
        step(f"checking {dep}")
        if shutil.which(dep) is None:
            missing.append(dep)
            print(f"{RED}✗ not found{RESET}")
        else:
            ok()
    if not SAGE.exists():
        missing.append("sage interpreter (deps/SageLang/sage)")
        step_warn("sage not built at deps/SageLang/sage — run make -C deps/SageLang first")
    if missing:
        step_fail(f"missing: {', '.join(missing)}")


def main() -> None:
    commands: dict[str, callable] = {
        "build": cmd_build,
        "build-all": cmd_build_all,
        "build-vscode": cmd_build_vscode,
        "install-vscode": cmd_install_vscode,
        "deploy": cmd_deploy,
        "check": cmd_check,
        "test": cmd_test,
        "run": cmd_run,
        "install": cmd_install,
        "clean": cmd_clean,
        "all": cmd_all,
    }

    if len(sys.argv) < 2 or sys.argv[1] not in commands:
        banner("JanusDBG — sagemake")
        print(f"  Usage:  ./sagemake {'|'.join(commands.keys())}")
        print()
        sys.exit(1)

    cmd = sys.argv[1]
    args = sys.argv[2:]
    check_dependencies()
    commands[cmd](args)


if __name__ == "__main__":
    main()
