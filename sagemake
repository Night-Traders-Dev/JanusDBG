#!/usr/bin/env python3
"""
sagemake — Build system for JanusDBG

Unified debugging and profiling for heterogeneous ARM + RISC-V SoCs.

Usage:
    ./sagemake [command] [flags]

Commands:
    build      Deploy binary for native arch
    build-all  Deploy binaries for all 6 targets (x86, x86_64, rv32, rv64, arm32, aarch64)
    check      Lint all Sage source files
    test       Run the test suite
    run        Run the backend in interpreter mode
    install    Install built artifact
    clean      Remove build artifacts
    deploy     Build deploy bundle only (no cross-compile)
    all        Run check → test → deploy
"""

import os
import platform
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

RESET = "\033[0m"
BOLD = "\033[1m"
RED = "\033[31m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
CYAN = "\033[36m"

ROOT = Path(__file__).resolve().parent
SAGE = ROOT / "deps" / "SageLang" / "sage"
SRC_DIR = ROOT / "src"
LIB_DIR = ROOT / "lib"
TEST_DIR = ROOT / "tests"
BUILD_DIR = ROOT / "build"
BINARY_NAME = "janusdbgd"

CROSS_TARGETS = {
    "x86":      "i686-linux-gnu-gcc",
    "x86_64":   "gcc",
    "rv32":     "riscv32-linux-gnu-gcc",
    "rv64":     "riscv64-linux-gnu-gcc",
    "arm32":    "arm-linux-gnueabi-gcc",
    "aarch64":  "aarch64-linux-gnu-gcc",
}

# Alias maps
TARGET_ALIASES = {
    "amd64": "x86_64", "i386": "x86", "i686": "x86",
    "riscv32": "rv32", "riscv64": "rv64",
    "arm": "arm32", "armhf": "arm32",
    "arm64": "aarch64",
}


def banner(title: str) -> None:
    width = 60
    line = f"{CYAN}{'═' * width}{RESET}"
    print(f"\n{line}")
    print(f"{CYAN}  {BOLD}{title}{RESET}")
    print(f"{line}\n")


def section(title: str) -> None:
    print(f"  {CYAN}→{RESET} {title}")


def step(msg: str) -> None:
    print(f"    {msg} ... ", end="", flush=True)


def ok() -> None:
    print(f"{GREEN}✓ done{RESET}")


def step_ok(detail: str) -> None:
    print(f"{GREEN}✓ {detail}{RESET}")


def step_fail(detail: str) -> None:
    print(f"{RED}✗ {detail}{RESET}")
    sys.exit(1)


def step_warn(detail: str) -> None:
    print(f"{YELLOW}! {detail}{RESET}")


def run_cmd(cmd: list[str], **kwargs) -> subprocess.CompletedProcess:
    try:
        return subprocess.run(cmd, check=True, **kwargs)
    except subprocess.CalledProcessError as e:
        step_fail(f"command failed: {' '.join(cmd)} (exit {e.returncode})")
    except FileNotFoundError:
        step_fail(f"command not found: {cmd[0]}")
    return None  # unreachable


def sage_source_files() -> list[Path]:
    files = []
    for d in [SRC_DIR, LIB_DIR]:
        for p in d.rglob("*.sage"):
            files.append(p)
    return sorted(files)


def cmd_check(args: list[str]) -> None:
    banner("check — JanusDBG")
    section("Linting source files")
    files = sage_source_files()
    errors = 0
    has_sage_lint = shutil.which("sage-lint") or SAGE.exists()
    if not has_sage_lint:
        step_warn("sage interpreter not found — skipping lint")
        return
    sage_bin = str(SAGE) if SAGE.exists() else "sage"
    for f in files:
        rel = f.relative_to(ROOT)
        step(f"linting {rel}")
        result = subprocess.run(
            [sage_bin, "lint", str(f)],
            capture_output=True, text=True,
        )
        if result.returncode != 0:
            errors += 1
            print(f"{RED}✗{RESET}")
            print(result.stdout)
        else:
            ok()
    if errors:
        step_fail(f"{errors} file(s) failed linting")


def cmd_test(args: list[str]) -> None:
    banner("test — JanusDBG")
    sage_path = f"{LIB_DIR}:{SRC_DIR}"
    env = os.environ.copy()
    env["SAGE_PATH"] = sage_path

    section("Test suite")
    step("running tests")
    if not SAGE.exists():
        step_fail("sage interpreter not built — run make -C deps/SageLang first")
    run_cmd([str(SAGE), str(TEST_DIR / "run_all.sage")], env=env)
    step_ok("all tests passed")


def cmd_deploy(args: list[str]) -> None:
    """Build the deploy bundle only (no cross-compile)."""
    banner("deploy — JanusDBG")
    section("Generating bundle")
    step("bundling source modules")
    deploy_script = ROOT / "tools" / "deploy.py"
    if not deploy_script.exists():
        step_fail("tools/deploy.py not found")
    env = os.environ.copy()
    result = subprocess.run(
        [sys.executable, str(deploy_script), "x86_64"],  # just generates bundle
        capture_output=True, text=True, env=env, cwd=ROOT,
    )
    if result.returncode != 0:
        print(result.stderr)
        step_fail("deploy failed")
    for line in result.stdout.splitlines():
        if "Output:" in line or "Bundled:" in line:
            step_ok(line.strip())
    step_ok("deploy bundle ready")


def cmd_build(args: list[str]) -> None:
    """Build for native architecture or a specific target."""
    banner("build — JanusDBG")

    # Determine target
    target = "x86_64"
    if args:
        t = args[0]
        target = TARGET_ALIASES.get(t, t)

    # Run tests first
    try:
        cmd_test([])
    except SystemExit:
        step_fail("tests must pass before build")

    section(f"Building for {target}")
    deploy_script = ROOT / "tools" / "deploy.py"
    if not deploy_script.exists():
        step_fail("tools/deploy.py not found")

    # Check cross-compiler availability
    cc = shutil.which(CROSS_TARGETS.get(target, "gcc"))
    if not cc:
        cc = shutil.which("gcc")
        if cc:
            step_warn(f"cross-compiler '{CROSS_TARGETS.get(target, '?')}' not found, using native gcc")
        else:
            step_fail(f"no C compiler found for target '{target}'")

    step("deploying")
    result = subprocess.run(
        [sys.executable, str(deploy_script), target],
        capture_output=True, text=True, cwd=ROOT,
    )
    if result.returncode != 0:
        print(result.stderr)
        step_fail(f"build failed for {target}")
    for line in result.stdout.splitlines():
        if "Output:" in line or "Warning:" in line or "Bundled:" in line:
            print(f"    {line.strip()}")

    # Run tests after build too
    try:
        cmd_test([])
    except SystemExit:
        step_fail("tests must pass after build")

    step_ok(f"{BINARY_NAME} built for {target}")


def cmd_build_all(args: list[str]) -> None:
    """Build for all 6 targets."""
    banner("build-all — JanusDBG")

    # Run tests first
    try:
        cmd_test([])
    except SystemExit:
        step_fail("tests must pass before build")

    env = os.environ.copy()
    deploy_script = ROOT / "tools" / "deploy.py"

    successes = []
    failures = []

    for target, cc_name in CROSS_TARGETS.items():
        section(f"Building for {target} ({cc_name})")
        cc = shutil.which(cc_name)
        if not cc:
            cc = shutil.which("gcc")
            if cc:
                step_warn(f"cross-compiler '{cc_name}' not found, using native gcc")
            else:
                step_warn(f"no C compiler found for {target}")
                failures.append(target)
                continue

        step("deploying")
        result = subprocess.run(
            [sys.executable, str(deploy_script), target],
            capture_output=True, text=True, cwd=ROOT,
        )
        if result.returncode != 0:
            step_warn(f"build failed for {target}")
            failures.append(target)
        else:
            for line in result.stdout.splitlines():
                if "Output:" in line or "Bundled:" in line:
                    print(f"    {line.strip()}")
            successes.append(target)

    print()
    print(f"  {GREEN}{len(successes)} targets succeeded{RESET}: {', '.join(successes)}")
    if failures:
        print(f"  {RED}{len(failures)} targets failed{RESET}: {', '.join(failures)}")

    # Run tests after build
    try:
        cmd_test([])
    except SystemExit:
        step_fail("tests must pass after build")

    if failures:
        step_fail("some targets failed")


def cmd_run(args: list[str]) -> None:
    banner("run — JanusDBG")
    sage_path = f"{LIB_DIR}:{SRC_DIR}"
    env = os.environ.copy()
    env["SAGE_PATH"] = sage_path
    section("Starting backend (interpreter mode)")
    if not SAGE.exists():
        step_fail("sage interpreter not built — run make -C deps/SageLang first")
    cmd = [str(SAGE), str(SRC_DIR / "main.sage")] + args
    run_cmd(cmd, env=env)


def cmd_install(args: list[str]) -> None:
    """Install deploy binary to /usr/local/bin."""
    banner("install — JanusDBG")
    install_dir = Path("/usr/local/bin")
    # Determine which binary to install
    target = args[0] if args else "x86_64"
    binary = BUILD_DIR / f"{BINARY_NAME}_{target}"
    if not binary.exists():
        step_fail(f"{binary.name} not built — run build {target} first")
    dest = install_dir / BINARY_NAME
    step(f"installing to {dest}")
    try:
        install_dir.mkdir(parents=True, exist_ok=True)
        shutil.copy2(binary, dest)
        dest.chmod(0o755)
    except PermissionError:
        step_fail(f"permission denied (try sudo)")
    step_ok(f"installed {BINARY_NAME}")


def cmd_clean(args: list[str]) -> None:
    banner("clean — JanusDBG")
    section("Removing build artifacts")
    step(f"removing {BUILD_DIR}")
    if BUILD_DIR.exists():
        shutil.rmtree(BUILD_DIR)
    ok()


def cmd_all(args: list[str]) -> None:
    cmd_check(args)
    cmd_test(args)
    cmd_deploy(args)


def check_dependencies() -> None:
    section("Dependencies")
    required = ["gcc"]
    missing = []
    for dep in required:
        step(f"checking {dep}")
        if shutil.which(dep) is None:
            missing.append(dep)
            print(f"{RED}✗ not found{RESET}")
        else:
            ok()
    if not SAGE.exists():
        missing.append("sage interpreter (deps/SageLang/sage)")
        step_warn("sage not built at deps/SageLang/sage — run make -C deps/SageLang first")
    if missing:
        step_fail(f"missing: {', '.join(missing)}")


def main() -> None:
    commands: dict[str, callable] = {
        "build": cmd_build,
        "build-all": cmd_build_all,
        "deploy": cmd_deploy,
        "check": cmd_check,
        "test": cmd_test,
        "run": cmd_run,
        "install": cmd_install,
        "clean": cmd_clean,
        "all": cmd_all,
    }

    if len(sys.argv) < 2 or sys.argv[1] not in commands:
        banner("JanusDBG — sagemake")
        print(f"  Usage:  ./sagemake {'|'.join(commands.keys())}")
        print()
        sys.exit(1)

    cmd = sys.argv[1]
    args = sys.argv[2:]
    check_dependencies()
    commands[cmd](args)


if __name__ == "__main__":
    main()
